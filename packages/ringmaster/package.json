{
  "name": "@mnke/ringmaster",
  "version": "0.1.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest"
  },
  "peerDependencies": {
    "typescript": "^5 || ^6.0.0"
  },
  "dependencies": {
    "@commander-js/extra-typings": "catalog:",
    "@kubernetes/client-node": "1.4.0",
    "@mnke/circus-shared": "workspace:*",
    "commander": "catalog:",
    "ioredis": "catalog:",
    "nats": "catalog:",
    "zod": "catalog:"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build --target=node --outfile=dist/index.js src/index.ts",
    "typecheck": "bun tsgo --noEmit",
    "start": "bun src/index.ts"
  }
}
