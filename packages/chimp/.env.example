# Claude API Configuration
ANTHROPIC_API_KEY=your_api_key_here

# Conduit Exchange Configuration (injected by the operator)
# These variables are automatically set by the Conduit operator when running in Kubernetes
# For local development, you'll need to set these manually

EXCHANGE_ID=example-exchange-id
EXCHANGE_NAME=conduit-chimp
EXCHANGE_NAMESPACE=default

# NATS Configuration
NATS_URL=nats://localhost:4222
NATS_STREAM_NAME=CHIMP_STREAM
NATS_CONSUMER_NAME=CHIMP_CONSUMER
NATS_SUBJECT_INPUT=chimp.input
NATS_SUBJECT_OUTPUT=chimp.output
NATS_SUBJECT_CONTROL=chimp.control

# Optional: Checkpoint and recovery
# CHECKPOINT_DATA={}
# IS_RECOVERING=false
# IN_CLUSTER=false
