{
  "name": "@mnke/circus",
  "version": "0.1.0",
  "module": "index.ts",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@fission-ai/openspec": "^1.3.0",
    "@types/bun": "latest",
    "lint-staged": "^16.4.0",
    "ocx": "^2.0.6",
    "shadcn": "^4.3.0",
    "typescript-language-server": "^5.1.3"
  },
  "peerDependencies": {
    "typescript": "^6.0.2",
    "@typescript/native-preview": "^7.0.0-dev.20260411.1"
  },
  "private": true,
  "scripts": {
    "typecheck": "bun run --filter='*' typecheck",
    "build": "bun run --filter='*' build",
    "format": "bun run biome format --write",
    "prepare": "husky"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "husky": "^9.1.7"
  },
  "catalog": {
    "nats": "^2.28.2",
    "ioredis": "^5.10.1",
    "pino": "^10.3.1",
    "zod": "^4.3.6",
    "commander": "^14.0.3",
    "@commander-js/extra-typings": "^14.0.0",
    "@octokit/app": "^16.1.2",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/webhooks": "^14.2.0"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
