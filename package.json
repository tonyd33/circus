{
  "name": "@mnke/circus",
  "version": "0.1.0",
  "module": "index.ts",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "latest",
    "lint-staged": "^16.4.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": true,
  "scripts": {
    "typecheck": "bun run --filter='*' typecheck",
    "build": "bun run --filter='*' build",
    "format": "bun run biome format --write",
    "prepare": "husky"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "husky": "^9.1.7"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
